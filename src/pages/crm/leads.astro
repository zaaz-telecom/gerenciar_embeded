---
import AppLayout from '../../layouts/AppLayout.astro';
import CrmSidebar from '../../components/CrmSidebar.astro';
import LeadForm from '../../modules/crm/components/LeadForm';
---

<AppLayout title="CRM | Leads">
    <CrmSidebar slot="sidebar" activeItem="novo-lead" />

    <div class="w-full px-4 py-6 sm:px-0 max-w-2xl mx-auto">
        <div class="mb-6 flex items-center justify-between">
            <h1 class="text-2xl font-bold text-gray-900">Novo Lead</h1>
            <a href="/crm" class="text-sm font-medium text-gray-500 hover:text-gray-900">
                &larr; Voltar
            </a>
        </div>
        <LeadForm client:only="react" />
    </div>
</AppLayout>
