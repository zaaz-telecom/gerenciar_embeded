---
import AppLayout from '../../layouts/AppLayout.astro';
import CrmSidebar from '../../components/CrmSidebar.astro';
import SaleWizard from '../../modules/crm/components/SaleWizard';
---

<AppLayout title="CRM | Nova Venda">
    <CrmSidebar slot="sidebar" activeItem="nova-venda" />
    <div class="w-full px-4 py-6 sm:px-0 max-w-4xl mx-auto">
        <div class="mb-6 flex items-center justify-between">
            <h1 class="text-2xl font-bold text-gray-900">Registrar Nova Venda</h1>
            <a href="/crm" class="text-sm font-medium text-gray-500 hover:text-gray-900">
                &larr; Voltar
            </a>
        </div>
        <SaleWizard client:only="react" />
    </div>
</AppLayout>
