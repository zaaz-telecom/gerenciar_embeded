---
import AppLayout from "../layouts/AppLayout.astro";
import TurnstileWidget from "../components/TurnstileWidget.astro";
import { supabaseAdmin } from "../lib/supabase";

let org = {
    name: "MIS",
    logo_url: "/favicon.png",
    subtitle: "Manager Operation Systems"
};

// Check if we are rendering on the server and have access to supabaseAdmin
if (supabaseAdmin) {
    let host = Astro.request.headers.get("x-forwarded-host") || Astro.request.headers.get("host") || "";
    if (host.includes(":")) host = host.split(":")[0]; // Strip port for DB matching

    const urlObj = new URL(Astro.request.url);
    if (urlObj.searchParams.get("tenant") === "zaaz") host = "bi.zaaztelecom.com.br";
    if (urlObj.searchParams.get("tenant") === "online") host = "online.net.br";

    const { data } = await supabaseAdmin
        .from("organization_domains")
        .select(`
            organizations (
                name,
                logo_url
            )
        `)
        .eq("domain", host)
        .limit(1);

    const domainData = data?.[0];
    if (domainData?.organizations) {
        const dbOrg = Array.isArray(domainData.organizations)
            ? domainData.organizations[0]
            : domainData.organizations;
            
        org.name = dbOrg.name || org.name;
        org.logo_url = dbOrg.logo_url || org.logo_url;
        
        if (org.name.toLowerCase().includes('zaaz')) {
            org.subtitle = 'DEPARTAMENTO DE PLANEJAMENTO E CONTROLE';
        } else if (org.name.toLowerCase().includes('online')) {
            org.subtitle = 'MIS';
        } else {
            org.subtitle = '';
        }
    }
}
---

<AppLayout title="Acessar Conta" disableNav={true}>
    <!-- Background Container -->
    <div id="login-background" class="fixed inset-0 w-full h-full bg-cover bg-center bg-no-repeat transition-all duration-700 ease-in-out bg-gray-50 z-0"></div>
    
    <div
        class="relative z-10 min-h-[calc(100vh-4rem)] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8"
    >
        <div
            class="max-w-md w-full space-y-8 bg-white p-8 rounded-2xl shadow-lg border border-gray-100 transition-all duration-300"
        >
            <div class="text-center" id="tenant-brand">
                <!-- Populated by JS via /api/auth/tenant -->
                <div class="flex flex-col items-center justify-center mb-6">
                    <img src={org.logo_url} alt={org.name} class="h-24 w-auto max-w-[250px] object-contain transition-all duration-300" id="tenant-logo-img" />
                    <h1 class="hidden text-4xl font-light text-text-primary tracking-tight" id="tenant-name">
                        {org.name}
                    </h1>
                    <p class={`text-xs text-text-secondary font-bold tracking-wide mt-3 text-center uppercase ${org.subtitle ? '' : 'hidden'}`} id="tenant-subtitle">
                        {org.subtitle}
                    </p>
                </div>
            </div>

            <div id="loginError" class="hidden rounded-md bg-red-50 p-4">
                <div class="flex">
                    <div class="shrink-0">
                        <svg
                            class="h-5 w-5 text-red-400"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <div class="ml-3">
                        <h3
                            class="text-sm font-medium text-red-800"
                            id="errorMessage"
                        >
                        </h3>
                    </div>
                </div>
            </div>

            <form class="mt-8 space-y-6" id="loginForm" method="POST">
                <div class="rounded-md shadow-sm -space-y-px">
                    <div class="mb-4">
                        <label for="identifier" class="sr-only">CPF ou Email</label>
                        <input
                            id="identifier"
                            name="identifier"
                            type="text"
                            autocomplete="username"
                            required
                            class="appearance-none rounded-md relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-text-primary focus:outline-none focus:ring-brand focus:border-brand focus:z-10 sm:text-sm"
                            placeholder="CPF ou Email corporativo"
                        />
                    </div>
                    <div>
                        <label for="password" class="sr-only">Senha</label>
                        <div class="relative">
                            <input
                                id="password"
                                name="password"
                                type="password"
                                autocomplete="current-password"
                                required
                                class="appearance-none rounded-md relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-text-primary focus:outline-none focus:ring-brand focus:border-brand focus:z-10 sm:text-sm pr-10"
                                placeholder="Senha"
                            />
                            <button
                                type="button"
                                id="togglePassword"
                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5 text-gray-500 hover:text-gray-700 focus:outline-none"
                            >
                                <svg
                                    class="h-5 w-5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                    ></path>
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                    ></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <div class="flex items-center">
                        <input
                            id="remember-me"
                            name="remember-me"
                            type="checkbox"
                            class="h-4 w-4 text-brand focus:ring-brand border-gray-300 rounded"
                        />
                        <label
                            for="remember-me"
                            class="ml-2 block text-sm text-text-secondary"
                        >
                            Lembrar-me
                        </label>
                    </div>

                    <div class="text-sm">
                        <a
                            href="/forgot-password"
                            class="font-medium text-brand hover:text-brand-dark"
                        >
                            Esqueceu a senha?
                        </a>
                    </div>
                </div>

                <!-- <TurnstileWidget /> -->
                <div>
                    <button
                        type="submit"
                        class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-brand hover:bg-brand-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                        <span
                            class="absolute left-0 inset-y-0 flex items-center pl-3"
                        >
                            <svg
                                class="h-5 w-5 text-brand-light group-hover:text-amber-50"
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 20 20"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </span>
                        Entrar
                    </button>
                </div>
            </form>

            <!-- A opção de cadastro foi ocultada temporariamente -->
        </div>
    </div>
</AppLayout>

<script>
    import { supabase } from "../lib/supabase";

    // Load org branding based on the current domain
    async function loadTenantBranding() {
        try {
            const searchParams = window.location.search;
            const res = await fetch('/api/auth/tenant' + searchParams);
            if (!res.ok) return;

            const { found, org } = await res.json();
            if (!found || !org) return;

            // Apply accent color
            if (org.accent_color) {
                document.documentElement.style.setProperty('--color-brand', org.accent_color);
            }

            // Apply logo
            const logoImg = document.getElementById('tenant-logo-img') as HTMLImageElement | null;
            if (logoImg && org.logo_url) {
                logoImg.src = org.logo_url;
                logoImg.alt = org.name || 'Logo';
            }

            // Update subtitle dynamically
            const subtitleEl = document.getElementById('tenant-subtitle');
            if (subtitleEl) {
                if (org.name && org.name.toLowerCase().includes('zaaz')) {
                    subtitleEl.textContent = 'DEPARTAMENTO DE PLANEJAMENTO E CONTROLE';
                    subtitleEl.classList.remove('hidden');
                } else if (org.name && org.name.toLowerCase().includes('online')) {
                    subtitleEl.textContent = 'MIS';
                    subtitleEl.classList.remove('hidden');
                } else {
                    subtitleEl.classList.add('hidden');
                }
            }

            // Update top-left navigation logo (AppLayout)
            const globalBrandLogo = document.getElementById("global-brand-logo");
            if (globalBrandLogo && org.logo_url) {
                globalBrandLogo.innerHTML = `<img src="${org.logo_url}" alt="${org.name}" class="h-8 w-auto object-contain" />`;
            }

            // Apply background
            const bgEl = document.getElementById('login-background');
            if (bgEl && org.login_background_url) {
                bgEl.style.backgroundImage = `url('${org.login_background_url}')`;
            }

        } catch (e) {
            // Fail silently — login still works with generic branding
        }
    }

    function initLogin() {
        const form = document.getElementById("loginForm") as HTMLFormElement;
        const errorDiv = document.getElementById("loginError");
        const errorMessage = document.getElementById("errorMessage");

        if (!form) return;

        // Check for error in query params
        const urlParams = new URLSearchParams(window.location.search);
        const error = urlParams.get('error');
        if (error === 'account_inactive' && errorDiv && errorMessage) {
            errorMessage.textContent = "Sua conta está inativa. Entre em contato com o administrador.";
            errorDiv.classList.remove("hidden");
        }

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            if (errorDiv) errorDiv.classList.add("hidden");

            const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
            const originalButtonText = button?.innerHTML || "Entrar";

            if (button) {
                button.innerText = "Entrando...";
                button.disabled = true;
            }

            const formData = new FormData(form);
            const identifier = formData.get("identifier")?.toString() || "";
            const password = formData.get("password")?.toString() || "";

            try {
                // 1. Lookup Email by CPF or verify existence
                const searchParams = window.location.search;
                const lookupRes = await fetch('/api/auth/lookup' + searchParams, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ identifier })
                });

                const lookupData = await lookupRes.json();

                if (!lookupRes.ok) {
                    throw new Error(lookupData.error || "Usuário não cadastrado no sistema.");
                }

                const email = lookupData.email;

                // 2. Server-side login (bypasses captcha requirement)
                const loginRes = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                const loginData = await loginRes.json();

                if (!loginRes.ok) {
                    throw new Error(loginData.error || "Erro ao autenticar.");
                }

                // 3. Set session on client-side Supabase instance
                if (loginData.session) {
                    await supabase.auth.setSession({
                        access_token: loginData.session.access_token,
                        refresh_token: loginData.session.refresh_token,
                    });
                }

                // 4. Redirect to dashboard
                window.location.href = "/users";
            } catch (err: any) {
                console.error("Login flow error:", err);
                if (errorDiv && errorMessage) {
                    errorMessage.textContent = err.message || "Erro inesperado. Tente novamente.";
                    errorDiv.classList.remove("hidden");
                }
                if (button) {
                    button.innerHTML = originalButtonText;
                    button.disabled = false;
                }
            }
        });

        // Password Toggle Logic
        const togglePassword = document.getElementById("togglePassword");
        const passwordInput = document.getElementById("password") as HTMLInputElement;

        togglePassword?.addEventListener("click", function () {
            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
            passwordInput.setAttribute("type", type);

            if (type === "text") {
                this.innerHTML = `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                 </svg>`;
            } else {
                this.innerHTML = `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                 </svg>`;
            }
        });

        // CPF Formatting Logic
        const identifierInput = document.getElementById("identifier") as HTMLInputElement;
        identifierInput?.addEventListener("input", (e) => {
            const input = e.target as HTMLInputElement;
            let value = input.value;
            // Se contiver qualquer letra ou arroba, tratamos como email e não aplicamos a máscara de CPF
            if (/[a-zA-Z@]/.test(value)) return;

            let digits = value.replace(/\D/g, '');
            if (digits.length <= 11) {
                if (digits.length > 9) {
                    value = digits.replace(/(\d{3})(\d{3})(\d{3})(\d{1,2})/, '$1.$2.$3-$4');
                } else if (digits.length > 6) {
                    value = digits.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1.$2.$3');
                } else if (digits.length > 3) {
                    value = digits.replace(/(\d{3})(\d{1,3})/, '$1.$2');
                } else {
                    value = digits;
                }
                input.value = value;
            }
        });
    }

    // Run on initial load
    loadTenantBranding();
    initLogin();

    // Re-run on Astro view transitions
    document.addEventListener('astro:page-load', () => {
        loadTenantBranding();
        initLogin();
    });
    document.addEventListener('DOMContentLoaded', () => {
        loadTenantBranding();
        initLogin();
    });

</script>
