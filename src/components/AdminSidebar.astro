---
interface Props {
    activeItem?: string;
}

const { activeItem } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (path: string, itemKey?: string) => {
    if (activeItem && itemKey) return activeItem === itemKey;
    return currentPath === path || currentPath.startsWith(path + "/");
};

// Styles for active state
const activeClasses = "bg-brand/5 text-brand font-semibold border-l-4 border-brand pl-2 -ml-2.5";
const inactiveClasses = "text-text-secondary hover:bg-gray-100 hover:text-text-primary pl-3";
---

<div slot="sidebar" class="space-y-4">
    <!-- Grupo Dashboard -->
    <div class="sidebar-group">
        <button
            class="w-full flex items-center justify-between cursor-pointer hover:bg-gray-50 rounded-md py-1 group-toggle"
            aria-expanded="true"
        >
            <div
                class="px-3 text-xs font-semibold text-text-secondary uppercase tracking-wider flex items-center gap-2"
            >
                Dashboard
            </div>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-3 w-3 text-text-tertiary mr-2 transition-transform duration-200 chevron rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path>
            </svg>
        </button>

        <div
            class="space-y-1 ml-2 border-l border-gray-200 pl-2 overflow-hidden transition-all duration-300 ease-in-out group-content max-h-[500px] opacity-100"
        >
            <a
                href="/admin/dashboards"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/dashboards", "dashboards") ? activeClasses : inactiveClasses}`}
            >
                Dashboards
            </a>
            <a
                href="/admin/settings"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/settings", "settings") ? activeClasses : inactiveClasses}`}
            >
                Power BI Embedded
            </a>
            <a
                href="/admin/menus"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/menus", "menus") ? activeClasses : inactiveClasses}`}
            >
                Menus
            </a>
        </div>
    </div>

    <!-- Grupo Organização -->
    <div class="sidebar-group">
        <button
            class="w-full flex items-center justify-between cursor-pointer hover:bg-gray-50 rounded-md py-1 group-toggle"
            aria-expanded="true"
        >
            <div
                class="px-3 text-xs font-semibold text-text-secondary uppercase tracking-wider flex items-center gap-2"
            >
                Organização
            </div>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-3 w-3 text-text-tertiary mr-2 transition-transform duration-200 chevron rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path>
            </svg>
        </button>

        <div
            class="space-y-1 ml-2 border-l border-gray-200 pl-2 overflow-hidden transition-all duration-300 ease-in-out group-content max-h-[500px] opacity-100"
        >
            <a
                href="/admin/departments"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/departments", "departments") ? activeClasses : inactiveClasses}`}
            >
                Departamentos
            </a>
            <a
                href="/admin/job-titles"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/job-titles", "job-titles") ? activeClasses : inactiveClasses}`}
            >
                Cargos
            </a>
            <a
                href="/admin/sectors"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/sectors", "sectors") ? activeClasses : inactiveClasses}`}
            >
                Setores
            </a>
        </div>
    </div>

    <!-- Grupo Geral -->
    <div class="sidebar-group">
        <button
            class="w-full flex items-center justify-between cursor-pointer hover:bg-gray-50 rounded-md py-1 group-toggle"
            aria-expanded="true"
        >
            <div
                class="px-3 text-xs font-semibold text-text-secondary uppercase tracking-wider flex items-center gap-2"
            >
                Geral
            </div>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-3 w-3 text-text-tertiary mr-2 transition-transform duration-200 chevron rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path>
            </svg>
        </button>

        <div
            class="space-y-1 ml-2 border-l border-gray-200 pl-2 overflow-hidden transition-all duration-300 ease-in-out group-content max-h-[500px] opacity-100"
        >
            <a
                href="/admin/company"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/company", "company") ? activeClasses : inactiveClasses}`}
            >
                Empresa
            </a>
            <a
                href="/admin/perfis"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/perfis", "perfis") ? activeClasses : inactiveClasses}`}
            >
                Perfis
            </a>
            <a
                href="/admin/subscription"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/subscription", "subscription") ? activeClasses : inactiveClasses}`}
            >
                Assinatura
            </a>
            <a
                href="/admin/email-provider"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/email-provider", "email-provider") ? activeClasses : inactiveClasses}`}
            >
                Provedor de Email
            </a>
            <a
                href="/admin/settings/emails"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/settings/emails", "email-logs") ? activeClasses : inactiveClasses}`}
            >
                Logs de Email
            </a>
            <a
                href="/admin/modules"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/modules", "modules") ? activeClasses : inactiveClasses}`}
            >
                Módulos
            </a>
            <a
                href="/admin/messages"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/messages", "messages") ? activeClasses : inactiveClasses}`}
            >
                Mensagens do Sistema
            </a>
            <a
                href="/admin/migration"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/migration", "migration") ? activeClasses : inactiveClasses}`}
            >
                Migração
            </a>
            <a
                href="/admin/audit-logs"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/audit-logs", "audit-logs") ? activeClasses : inactiveClasses}`}
            >
                Auditoria (Logs)
            </a>
            <a
                href="/admin/settings/voors"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/settings/voors", "voors") ? activeClasses : inactiveClasses}`}
            >
                Integração Voors
            </a>
            <a
                href="/admin/crm"
                class={`block py-2 text-sm transition-all duration-200 rounded-r-md ${isActive("/admin/crm", "crm") ? activeClasses : inactiveClasses}`}
            >
                CRM (PAP)
            </a>
        </div>
    </div>
</div>

<script>
    function setupToggles() {
        const toggles = document.querySelectorAll(".group-toggle");

        toggles.forEach((toggle) => {
            if (toggle.hasAttribute("data-initialized")) return;
            toggle.setAttribute("data-initialized", "true");

            const chevron = toggle.querySelector(".chevron");
            const content = toggle.nextElementSibling as HTMLElement;

            if (!content) return;

            // Check if this group contains an active link
            const hasActiveLink = content.querySelector(".border-l-4") !== null;
            
            // Set initial state based on active link
            if (hasActiveLink) {
                toggle.setAttribute("aria-expanded", "true");
                content.classList.remove("max-h-0", "opacity-0");
                content.classList.add("max-h-[500px]", "opacity-100");
                if (chevron) chevron.classList.add("rotate-180");
            } else {
                // Keep default or close if not active? 
                // Let's default to closed for non-active groups if they were previously open but not active.
                // Or just keep the default HTML state.
            }

            toggle.addEventListener("click", () => {
                const isExpanded =
                    toggle.getAttribute("aria-expanded") === "true";

                toggle.setAttribute("aria-expanded", String(!isExpanded));

                if (isExpanded) {
                    content.classList.remove("max-h-[500px]", "opacity-100");
                    content.classList.add("max-h-0", "opacity-0");
                    if (chevron) chevron.classList.remove("rotate-180");
                } else {
                    content.classList.remove("max-h-0", "opacity-0");
                    content.classList.add("max-h-[500px]", "opacity-100");
                    if (chevron) chevron.classList.add("rotate-180");
                }
            });
        });
    }

    document.addEventListener("astro:page-load", setupToggles);
    document.addEventListener("DOMContentLoaded", setupToggles);
</script>
