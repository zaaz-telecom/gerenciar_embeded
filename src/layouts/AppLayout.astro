---
import "../styles/global.css";
import "../styles/global.css";
import ProfileModal from "../components/ProfileModal";
import { SystemMessageManager } from "../components/SystemMessageManager";
import { NotificationBell } from "../components/NotificationBell";
import { HelpDeskWidget } from "../components/HelpDeskWidget";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  disableNav?: boolean;
  showAuthButtons?: boolean;
  fullWidth?: boolean;
  authOnlyNav?: boolean;
  hideSidebar?: boolean;
  rawSidebar?: boolean;
}

const {
  title,
  disableNav = false,
  showAuthButtons = false,
  fullWidth = false,
  authOnlyNav = false,
  hideSidebar = false,
  rawSidebar = false,
} = Astro.props;

import { supabaseAdmin } from "../lib/supabase";

let ssrOrgName = "MIS";
let ssrLogoUrl = "";
let ssrAccentColor = "";

if (supabaseAdmin) {
    let host = Astro.request.headers.get("x-forwarded-host") || Astro.request.headers.get("host") || "";
    if (host.includes(":")) host = host.split(":")[0];
    host = host.replace(/^www\./, "");
    
    const urlObj = new URL(Astro.request.url);
    if (urlObj.searchParams.get("tenant") === "zaaz") host = "bi.zaaztelecom.com.br";
    if (urlObj.searchParams.get("tenant") === "online") host = "online.net.br";

    const { data } = await supabaseAdmin
        .from("organization_domains")
        .select(`organizations (name, logo_url, accent_color)`)
        .eq("domain", host)
        .limit(1);

    const domainData = data?.[0];
    if (domainData?.organizations) {
        const dbOrg = Array.isArray(domainData.organizations) ? domainData.organizations[0] : domainData.organizations;
        ssrOrgName = dbOrg.name || ssrOrgName;
        ssrLogoUrl = dbOrg.logo_url || ssrLogoUrl;
        ssrAccentColor = dbOrg.accent_color || ssrAccentColor;
    }
}
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="SaaS B2B Platform" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | MIS</title>
    <ClientRouter />
    {ssrAccentColor && (
      <style define:vars={{ brandColor: ssrAccentColor }}>
        :root {
          --color-brand: var(--brandColor);
        }
      </style>
    )}
  </head>
  <body
    class="bg-surface text-text-primary h-screen flex flex-col overflow-hidden"
  >
    <!-- 1. Global Header -->
    <header
      class="h-14 bg-white border-b border-gray-200 flex items-center justify-between px-6 shrink-0 z-20 shadow-sm relative"
    >
      <div class="flex items-center gap-8">
        <a
          href="/"
          class="text-xl font-semibold text-brand tracking-tight flex items-center gap-2"
          id="global-brand-logo"
        >
          {ssrLogoUrl ? (
            <img src={ssrLogoUrl} alt={ssrOrgName} class="h-8 w-auto object-contain" />
          ) : (
            <>
              <span>🔷</span>
              <span id="org-name-header">{ssrOrgName}</span>
            </>
          )}
        </a>

        <!-- Module Navigation -->
        {
          !disableNav && (
            <nav
              id="module-nav"
              class="hidden md:flex gap-6"
              data-auth-only={authOnlyNav}
              style={authOnlyNav ? "display: none;" : ""}
            >
              <a
                id="nav-dashboards"
                href="/dashboard"
                class="text-sm font-medium text-text-primary hover:text-brand border-b-2 border-transparent hover:border-brand py-4 transition-colors"
                title="Visão Geral"
              >
                Dashboards
              </a>
              <a
                id="nav-crm"
                href="/crm"
                class="text-sm font-medium text-text-primary hover:text-brand border-b-2 border-transparent hover:border-brand py-4 transition-colors"
                title="CRM e Vendas PAP"
                style="display: none;"
              >
                CRM
              </a>
              <a
                id="nav-users"
                href="/users"
                class="text-sm font-medium text-text-secondary hover:text-brand border-b-2 border-transparent hover:border-brand py-4 transition-colors"
                title="Gestão de Acessos"
                style="display: none;"
              >
                Usuários
              </a>
              <a
                id="nav-indicators"
                href="/indicators"
                class="text-sm font-medium text-text-primary hover:text-brand border-b-2 border-transparent hover:border-brand py-4 transition-colors"
                title="Acompanhamento de Metas"
                style="display: none;"
              >
                Indicadores
              </a>
              <a
                id="nav-processes"
                href="/processes"
                class="text-sm font-medium text-text-primary hover:text-brand border-b-2 border-transparent hover:border-brand py-4 transition-colors"
                title="Gestão de Processos"
                style="display: none;"
              >
                Processos
              </a>
              <a
                id="nav-settings"
                href="/admin/settings"
                class="text-sm font-medium text-text-primary hover:text-brand border-b-2 border-transparent hover:border-brand py-4 transition-colors"
                title="Configurações do Sistema"
                style="display: none;"
              >
                Configuração
              </a>
            </nav>
          )
        }
      </div>

      <div class="flex items-center gap-4">
        <!-- Guest Nav (Login/Register) -->
        {
          showAuthButtons && (
            <div id="guest-buttons" class="flex items-center gap-3">
              <a
                href="/login"
                class="hidden md:inline-flex text-sm font-semibold text-brand hover:underline px-3 py-2"
              >
                Entrar
              </a>
              <a
                href="/register"
                class="inline-flex items-center justify-center rounded-md text-sm font-semibold bg-brand text-white hover:bg-brand-dark px-4 py-2 shadow-sm transition-colors"
              >
                Criar conta
              </a>
            </div>
          )
        }

        <!-- User Info (Hidden by default, shown via JS) -->
        <div
          id="user-info"
          class="relative flex items-center gap-3"
          style="display: none;"
        >
          <NotificationBell client:idle />

          <div class="relative">
            <button
              id="user-menu-button"
              class="flex items-center gap-3 p-1 rounded-full hover:bg-gray-50 transition-colors focus:outline-none"
            >
              <span
                id="org-name"
                class="text-sm font-medium text-text-secondary hidden md:block"
                >Empresa</span
              >
              <div
                id="user-avatar"
                class="h-8 w-8 rounded-full bg-brand-light text-brand font-bold flex items-center justify-center text-xs ring-2 ring-white shadow-sm"
              >
                U
              </div>
            </button>

            <!-- Dropdown Menu -->
            <div
              id="user-dropdown"
              class="hidden absolute right-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 focus:outline-none z-50 transform origin-top-right transition-all duration-200"
              role="menu"
            >
              <div class="px-4 py-3 border-b border-gray-100">
                <p
                  class="text-xs text-text-secondary uppercase tracking-wider font-semibold"
                >
                  Logado como
                </p>
                <p
                  id="user-email"
                  class="text-sm font-medium text-text-primary truncate mt-1"
                >
                  ...
                </p>
              </div>

              <div class="py-1 border-b border-gray-100">
                <button
                  id="profile-button"
                  class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand flex items-center gap-2 transition-colors"
                  role="menuitem"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    ></path>
                  </svg>
                  Editar Perfil
                </button>
                <button
                  id="password-button"
                  class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand flex items-center gap-2 transition-colors"
                  role="menuitem"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                    ></path>
                  </svg>
                  Alterar Senha
                </button>
              </div>

              <div class="py-1">
                <button
                  id="logout-button"
                  class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand flex items-center gap-2 transition-colors"
                  role="menuitem"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
                    ></path>
                  </svg>
                  Sair
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Synchronous script to prevent FOUC (Flash of Unstyled Content) -->
    <script is:inline>
      try {
        const isPublicPage = ["/login", "/register", "/", "/forgot-password", "/update-password"].includes(
          window.location.pathname,
        );
        if (isPublicPage) {
          localStorage.removeItem("tenantContext");
        } else {
          const tenantStr = localStorage.getItem("tenantContext");
          if (tenantStr) {
            const tenant = JSON.parse(tenantStr);

            if (tenant.color) {
              document.documentElement.style.setProperty(
                "--color-brand",
                tenant.color,
              );
            }

            if (tenant.name) {
              const orgNameEl = document.getElementById("org-name");
              if (orgNameEl) orgNameEl.textContent = tenant.name;
            }

            const brandContainer = document.getElementById("global-brand-logo");
            if (brandContainer) {
              if (tenant.logo) {
                brandContainer.innerHTML = `<img src="${tenant.logo}" alt="${tenant.name || ""}" class="h-8 w-auto object-contain" />`;
              } else if (tenant.name) {
                brandContainer.innerHTML = `<span>🔷</span><span id="org-name-header">${tenant.name}</span>`;
              }
            }

            // --- Menu warming optimization (Avoid FOPC/FOUC) ---
            const permsStr = localStorage.getItem("navPermissions");
            if (permsStr) {
              const perms = JSON.parse(permsStr);
              if (perms.crm) document.getElementById("nav-crm").style.display = "";
              if (perms.users) document.getElementById("nav-users").style.display = "";
              if (perms.indicators) document.getElementById("nav-indicators").style.display = "";
              if (perms.processes) document.getElementById("nav-processes").style.display = "";
              if (perms.settings) document.getElementById("nav-settings").style.display = "";
            }
          }
        }
      } catch (e) {}
    </script>

    <div class="flex flex-1 overflow-hidden">
      <!-- 2. Context Sidebar -->
      <!-- 2. Context Sidebar -->
      {
        !disableNav && !hideSidebar && rawSidebar ? (
          <slot name="sidebar" />
        ) : (
          !disableNav &&
          !hideSidebar && (
            <aside class="hidden md:flex w-64 bg-gray-50/50 border-r border-gray-200 flex flex-col shrink-0">
              <div class="p-4 h-full flex flex-col">
                <slot name="sidebar">
                  <p class="text-xs text-text-secondary px-2">Menu Principal</p>
                </slot>
              </div>
            </aside>
          )
        )
      }

      <!-- 3. Main Content -->
      <main
        class={`flex-1 overflow-auto bg-surface ${fullWidth ? "p-0" : "p-6 md:p-8"}`}
      >
        <div
          class={`${fullWidth ? "h-full flex flex-col" : "max-w-7xl mx-auto h-full flex flex-col"}`}
        >
          <slot />
        </div>
      </main>
    </div>

    <!-- Modals and Floating Elements -->
    <ProfileModal client:idle />
    <SystemMessageManager client:only="react" />
    <HelpDeskWidget client:only="react" />

    <script>
      import { supabase } from "../lib/supabase";

      // Permission Helper
      async function checkPermissions(session: any) {
        if (!session?.user) return { isOrgAdmin: false, permissions: null };

        try {
          const { fetchUserPermissions } = await import("../utils/permissions");
          return await fetchUserPermissions(session.user.id);
        } catch (e) {
          console.error("Error loading permissions:", e);
          const { data: profile } = await supabase
            .from("profiles")
            .select("role")
            .eq("id", session.user.id)
            .single();
          return { isOrgAdmin: profile?.role === "admin", permissions: null };
        }
      }

      const updateHeader = async () => {
        try {
          // Pages where we should NOT show user info even if there's a session
          const authOnlyPages = ["/update-password", "/forgot-password", "/login", "/register"];
          const isAuthOnlyPage = authOnlyPages.includes(window.location.pathname);

          const {
            data: { session },
          } = await supabase.auth.getSession();

          const userInfo = document.getElementById("user-info");
          const guestButtons = document.getElementById("guest-buttons");
          const orgNameEl = document.getElementById("org-name");
          const avatarEl = document.getElementById("user-avatar");
          const moduleNav = document.getElementById("module-nav");

          // Nav Items
          const navDashboards = document.getElementById("nav-dashboards");
          const navCrm = document.getElementById("nav-crm");
          const navUsers = document.getElementById("nav-users");
          const navIndicators = document.getElementById("nav-indicators");
          const navProcesses = document.getElementById("nav-processes");
          const navSettings = document.getElementById("nav-settings");

          if (!session?.user || isAuthOnlyPage) {
            if (userInfo) userInfo.style.display = "none";
            if (guestButtons) guestButtons.style.display = isAuthOnlyPage ? "none" : "flex";
            if (moduleNav) moduleNav.style.display = "none";
            return;
          }

          if (guestButtons) guestButtons.style.display = "none";
          if (moduleNav) moduleNav.style.display = "";

          // Fetch Permissions
          const { permissions, isOrgAdmin } = await checkPermissions(session);
          const { hasPermission } = await import("../utils/permissions");

          // Update Nav Visibility based on permissions
          const canViewCrm = hasPermission(permissions, "crm", "view", isOrgAdmin) || hasPermission(permissions, "crm_admin", "view_all", isOrgAdmin);
          const canViewUsers = hasPermission(
            permissions,
            "users",
            "view",
            isOrgAdmin,
          );
          const canViewIndicators = hasPermission(
            permissions,
            "indicators",
            "view",
            isOrgAdmin,
          );
          const canViewProcesses = hasPermission(
            permissions,
            "processes",
            "view",
            isOrgAdmin,
          );
          const canManageSettings = hasPermission(
            permissions,
            "organization",
            "manage_settings",
            isOrgAdmin,
          );

          if (navCrm) navCrm.style.display = canViewCrm ? "" : "none";
          if (navUsers) navUsers.style.display = canViewUsers ? "" : "none";
          if (navIndicators)
            navIndicators.style.display = canViewIndicators ? "" : "none";
          if (navProcesses)
            navProcesses.style.display = canViewProcesses ? "" : "none";
          if (navSettings)
            navSettings.style.display = canManageSettings ? "" : "none";

          // Cache permissions to avoid flicker on next load
          localStorage.setItem("navPermissions", JSON.stringify({
            crm: canViewCrm,
            users: canViewUsers,
            indicators: canViewIndicators,
            processes: canViewProcesses,
            settings: canManageSettings
          }));

          // Route Protection (Simple client-side check)
          const path = window.location.pathname;
          if (path.startsWith("/users") && !canViewUsers) {
            window.location.href = "/dashboard";
            return;
          }
          if (path.startsWith("/indicators") && !canViewIndicators) {
            window.location.href = "/dashboard";
            return;
          }
          if (path.startsWith("/processes") && !canViewProcesses) {
            window.location.href = "/dashboard";
            return;
          }
          if (path.startsWith("/admin") && !canManageSettings) {
            window.location.href = "/dashboard";
            return;
          }

          const { data: profile } = await supabase
            .from("profiles")
            .select(
              `
              full_name,
              status,
              organizations (
                name,
                logo_url,
                accent_color
              )
            `,
            )
            .eq("id", session.user.id)
            .single();

          if (profile?.status === 'inactive') {
            localStorage.removeItem("tenantContext");
            localStorage.removeItem("navPermissions");
            await supabase.auth.signOut();
            window.location.href = "/login?error=account_inactive";
            return;
          }

          if (profile?.organizations) {
            // @ts-ignore
            const org = (
              Array.isArray(profile.organizations)
                ? profile.organizations[0]
                : profile.organizations
            ) as any;

            if (orgNameEl) orgNameEl.textContent = org.name;
            const orgTitleEl = document.getElementById("org-name-header");
            if (orgTitleEl) orgTitleEl.textContent = org.name;

            if (org.accent_color) {
              const root = document.documentElement;
              // Set the brand css variables only if different
              if (root.style.getPropertyValue("--color-brand") !== org.accent_color) {
                root.style.setProperty("--color-brand", org.accent_color);
              }
            }

            const brandContainer = document.getElementById("global-brand-logo");
            if (brandContainer) {
              if (org.logo_url) {
                // Only update if it's actually different to prevent DOM flashing
                const currentImg = brandContainer.querySelector('img');
                if (!currentImg || currentImg.getAttribute('src') !== org.logo_url) {
                  brandContainer.innerHTML = `<img src="${org.logo_url}" alt="${org.name}" class="h-8 w-auto object-contain" />`;
                }
              } else {
                // If no logo, ensure the default is set
                if (!brandContainer.querySelector('span')) {
                  brandContainer.innerHTML = `<span>🔷</span><span id="org-name-header">${org.name}</span>`;
                }
              }
            }

            // Guardar context p/ evitar piscada no próximo recarregamento (FOUC)
            localStorage.setItem(
              "tenantContext",
              JSON.stringify({
                name: org.name,
                logo: org.logo_url,
                color: org.accent_color,
              }),
            );
          }

          if (profile && userInfo) {
            if (avatarEl && profile.full_name) {
              const initials = profile.full_name
                .split(" ")
                .map((n: any) => n[0])
                .slice(0, 2)
                .join("")
                .toUpperCase();
              avatarEl.textContent = initials;
            }

            const emailEl = document.getElementById("user-email");
            if (emailEl && session.user.email) {
              emailEl.textContent = session.user.email;
            }

            userInfo.style.display = "flex";
          }
        } catch (e) {
          console.error("Error updating header:", e);
        }
      };

      // Listen for auth changes
      supabase.auth.onAuthStateChange((event, session) => {
        if (event === "SIGNED_OUT") {
          const userInfo = document.getElementById("user-info");
          const guestButtons = document.getElementById("guest-buttons");
          const moduleNav = document.getElementById("module-nav");

          if (userInfo) userInfo.style.display = "none";
          if (guestButtons) guestButtons.style.display = "flex";

          if (moduleNav && moduleNav.dataset.authOnly === "true") {
            moduleNav.style.display = "none";
          }
        } else if (event === "SIGNED_IN") {
          const authOnlyPages = ["/update-password", "/forgot-password", "/login", "/register"];
          if (!authOnlyPages.includes(window.location.pathname)) {
            updateHeader();
          }
        }
      });

      // View Transitions support: run updateHeader on every navigation
      document.addEventListener('astro:page-load', () => {
        updateHeader();
      });

      window.addEventListener("profile-updated", () => {
        updateHeader();
      });

      updateHeader();

      // Dropdown Logic
      const menuButton = document.getElementById("user-menu-button");
      const dropdown = document.getElementById("user-dropdown");
      const logoutBtn = document.getElementById("logout-button");

      if (menuButton && dropdown) {
        menuButton.addEventListener("click", (e) => {
          e.stopPropagation();
          dropdown.classList.toggle("hidden");
        });

        const profileBtn = document.getElementById("profile-button");
        const passwordBtn = document.getElementById("password-button");

        if (profileBtn) {
          profileBtn.addEventListener("click", () => {
            dropdown.classList.add("hidden");
            window.dispatchEvent(
              new CustomEvent("open-profile-modal", {
                detail: { mode: "profile" },
              }),
            );
          });
        }

        if (passwordBtn) {
          passwordBtn.addEventListener("click", () => {
            dropdown.classList.add("hidden");
            window.dispatchEvent(
              new CustomEvent("open-profile-modal", {
                detail: { mode: "security" },
              }),
            );
          });
        }

        document.addEventListener("click", (e) => {
          if (
            !menuButton.contains(e.target as Node) &&
            !dropdown.contains(e.target as Node)
          ) {
            dropdown.classList.add("hidden");
          }
        });
      }

      if (logoutBtn) {
        logoutBtn.addEventListener("click", async () => {
          localStorage.removeItem("tenantContext");
          localStorage.removeItem("navPermissions");
          await supabase.auth.signOut();
          window.location.href = "/login";
        });
      }
    </script>
  </body>
</html>
